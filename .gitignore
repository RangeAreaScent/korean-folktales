# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local artifacts
.playwright-mcp/
.screenshots/
/coloring images/
*.png
!public/**/*.png
!src/**/*.png
.backups/

# Working folder for raw sound source files (compressed copies live in public/sounds/)
/sound/

# Stray root PNGs (defense in depth — should never sneak back)
/*.png
